---
import BaseHeader from '@/components/common/base-header.astro';
import { skills, videoWorks } from '@/data/videos';
import MainLayout from '@/layouts/main-layout.astro';
---

<MainLayout>
  <BaseHeader
    title="영상 ﹒ Video"
    subtitle="영상 편집, 모션 그래픽, 그리고 시각적 스토리텔링 작업들을 소개합니다."
  />

  <section class="space-y-8">
    <div class="grid gap-6 md:grid-cols-2">
      {
        videoWorks.map((work) => (
          <article class="border-border overflow-hidden rounded-lg border transition-shadow hover:shadow-sm">
            <div class="flex aspect-video items-center justify-center bg-gray-200 dark:bg-gray-800">
              <div class="text-center">
                <div class="bg-primary mx-auto mb-2 flex h-12 w-12 items-center justify-center rounded-full">
                  <svg
                    class="h-6 w-6 text-white"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                  >
                    <path d="M8 5v10l8-5-8-5z" />
                  </svg>
                </div>
                <span class="text-second text-sm">{work.duration}</span>
              </div>
            </div>

            <div class="p-6">
              <div class="mb-3 flex items-start justify-between">
                <h3 class="text-heading text-lg font-medium">
                  <a
                    href={work.href}
                    class="text-primary hover:text-primary-light transition-colors"
                  >
                    {work.title}
                  </a>
                </h3>
                <span class="text-second rounded bg-gray-100 px-2 py-1 text-xs dark:bg-gray-800">
                  {work.category}
                </span>
              </div>

              <p class="text-second">{work.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-heading mb-6 text-xl font-semibold">기술 및 도구</h2>

    <div class="grid gap-6 md:grid-cols-2">
      {
        skills.map((skillGroup) => (
          <div>
            <h3 class="text-heading mb-3 font-medium">{skillGroup.category}</h3>
            <ul class="text-second space-y-2">
              {skillGroup.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</MainLayout>
